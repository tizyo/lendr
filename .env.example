APP_NAME=LENDR
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_URL=http://localhost:8080
CENTRAL_DOMAIN=lendr.app

APP_LOCALE=en
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=en_US

APP_MAINTENANCE_DRIVER=file

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

# ─── Database ────────────────────────────────────────────
DB_CONNECTION=mysql
DB_HOST=127.0.0.1
DB_PORT=3307
DB_DATABASE=lendr
DB_USERNAME=lendr
DB_PASSWORD=lendr_secret
DB_ROOT_PASSWORD=root_secret

# ─── Session / Cache / Queue ─────────────────────────────
SESSION_DRIVER=redis
SESSION_LIFETIME=480
SESSION_ENCRYPT=true
SESSION_PATH=/
SESSION_DOMAIN=.lendr.app

BROADCAST_CONNECTION=reverb
FILESYSTEM_DISK=s3
QUEUE_CONNECTION=redis

CACHE_STORE=redis
CACHE_PREFIX=lendr_

# ─── Redis ───────────────────────────────────────────────
REDIS_CLIENT=predis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=redis_secret
REDIS_PORT=6380

# ─── Mail ────────────────────────────────────────────────
MAIL_MAILER=smtp
MAIL_SCHEME=null
MAIL_HOST=127.0.0.1
MAIL_PORT=1025
MAIL_USERNAME=null
MAIL_PASSWORD=null
MAIL_FROM_ADDRESS="noreply@lendr.app"
MAIL_FROM_NAME="LENDR"

# ─── AWS / S3 ────────────────────────────────────────────
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_DEFAULT_REGION=af-south-1
AWS_BUCKET=lendr-files
AWS_USE_PATH_STYLE_ENDPOINT=false
AWS_URL=

# Cloudflare R2 (alternative to S3)
CLOUDFLARE_R2_ACCESS_KEY_ID=
CLOUDFLARE_R2_SECRET_ACCESS_KEY=
CLOUDFLARE_R2_BUCKET=lendr-files
CLOUDFLARE_R2_ENDPOINT=

# ─── SMS Gateways ────────────────────────────────────────
SMS_GATEWAY=twilio
TWILIO_SID=
TWILIO_TOKEN=
TWILIO_FROM=

SMS_TO_API_KEY=
CLICKATELL_API_KEY=

# ─── Mobile Money ────────────────────────────────────────
MOMO_GATEWAY=flutterwave
FLUTTERWAVE_PUBLIC_KEY=
FLUTTERWAVE_SECRET_KEY=
FLUTTERWAVE_WEBHOOK_SECRET=

PAWAPAY_API_KEY=
PAWAPAY_WEBHOOK_SECRET=

LIPILA_API_KEY=
LIPILA_WEBHOOK_SECRET=

# ─── Horizon ─────────────────────────────────────────────
HORIZON_ENABLED=true
HORIZON_BASIC_AUTH_USER=lendr
HORIZON_BASIC_AUTH_PASSWORD=

# ─── Telescope ───────────────────────────────────────────
TELESCOPE_ENABLED=false

# ─── Sentry ──────────────────────────────────────────────
SENTRY_LARAVEL_DSN=

# ─── Vite ────────────────────────────────────────────────
VITE_APP_NAME="${APP_NAME}"
VITE_APP_URL="${APP_URL}"
